# Mobile Unit — environment variables
# Copy to .env.local for local development.
# NEXT_PUBLIC_* values are bundled into the client. Everything else is server-only.

# -------- Public site --------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=el
NEXT_PUBLIC_VERIFICATION_LABEL=iRepair
NEXT_PUBLIC_PANDAS_PRICING_URL=https://pandas.io/pricing

# -------- Supabase --------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
SUPABASE_JWT_SECRET=your-jwt-secret

# -------- Anthropic (assistant) --------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# -------- Resend (transactional email) --------
RESEND_API_KEY=re_...
RESEND_FROM=Mobile Unit <noreply@mobileunit.gr>

# -------- Upstash Redis (rate limiting) --------
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -------- Sentry (error tracking) --------
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# -------- Missive (fraud alert drafts, optional) --------
# If unset, fraud alerts are logged only — no draft created.
MISSIVE_API_KEY=
MISSIVE_ORG_ID=

# -------- V2: Stripe Connect (unused in V1) --------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
